# Copy to .env and fill in. All optional — the app runs with sensible defaults.

# Port the server listens on.
PORT=8787

# Where state (data.json) and signing keys are persisted. In Docker this is a
# mounted volume so data survives redeploys. Locally, leave unset to use ./server.
DATA_DIR=/data

# Stripe — leave BOTH unset to run in simulated-billing mode (no real charges).
# Set them to switch to live Stripe (test keys sk_test_/whsec_ are fine to start).
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
